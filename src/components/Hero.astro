      <!-- Duplicate for seamless loop -->
      <div class='flex items-center gap-8'>
        <!-- Cake Icon + Text -->
        <div class='flex items-center gap-3 whitespace-nowrap'>
          <svg
            class='w-6 h-6 text-gray-600'
            fill='none'
            stroke='currentColor'
            viewBox='0 0 24 24'
          >
            <path
              stroke-linecap='round'
              stroke-linejoin='round'
