---
import { downloadStrapiImage, type HeroSection } from '../lib/strapi'

interface Props {
  heroData: HeroSection | null
}

const { heroData } = Astro.props

// High-quality cake images for cascading card carousel
const cakeImages = ['/uploads/cake-18th.png', '/uploads/table-cake1.png']
---

<section
  class='relative w-full overflow-hidden'
  style='background: linear-gradient(135deg, #FAF6F1 0%, #F5EFE6 100%);'
>
  <!-- Split Layout Container -->
  <div
    class='grid grid-cols-1 lg:grid-cols-[40%_60%] gap-0 lg:gap-8 min-h-[calc(100vh-80px)] sm:min-h-[calc(85vh-80px)] lg:min-h-[calc(75vh-80px)] items-center'
  >
    <!-- Left Side - Text Content -->
    <div
      class='px-6 sm:px-8 md:px-12 lg:px-16 lg:pr-8 py-8 sm:py-12 lg:py-0 order-2 lg:order-1 text-center sm:text-left lg:text-right'
      style="font-family: 'Hanken Grotesk', sans-serif;"
    >
      <h1
        class='text-3xl sm:text-4xl md:text-5xl lg:text-6xl xl:text-7xl mb-6 sm:mb-8 leading-tight'
        style='font-weight: 500;'
      >
        <span class='block mb-2' style='color: #B8860B; letter-spacing: 0.02em;'
          >SIGNATURE YUMYUM</span
        >
        <span class='text-gray-900 block' style='letter-spacing: 0.01em;'
          >CLOUD-SOFT CAKES</span
        >
      </h1>

      <div class='flex justify-center sm:justify-start lg:justify-end'>
        <a
          href='/menu'
          class='inline-block text-white px-8 sm:px-10 lg:px-12 py-3 sm:py-3.5 lg:py-4 rounded-full text-sm sm:text-base transition-all shadow-lg hover:shadow-xl transform hover:scale-105 active:scale-95 w-full sm:w-auto text-center'
          style='background-color: #B8860B; font-weight: 500; letter-spacing: 0.08em; max-width: 280px;'
        >
          BROWSE ALL
        </a>
      </div>
    </div>

    <!-- Right Side - Cascading Card Carousel -->
    <div
      class='relative h-[380px] sm:h-[420px] md:h-[480px] lg:h-[calc(75vh-80px)] flex items-center justify-center order-1 lg:order-2 px-6 sm:px-8 lg:px-8 lg:pl-4'
    >
      <div
        id='card-carousel'
        class='relative w-full max-w-[320px] sm:max-w-md md:max-w-lg h-[350px] sm:h-[400px] md:h-[480px] lg:h-[550px]'
      >
        {
          cakeImages.map((image, index) => (
            <div
              class={`cake-card absolute transition-all duration-1000 ease-in-out ${index === 0 ? 'active' : ''}`}
              data-card={index}
              style={`
                //:background: white;
                // border-radius: 16px;
                // box-shadow: 0 20px 60px rgba(0, 0, 0, 0.15);
                //padding: 16px;
                width: 100%;
                max-width: 450px;
                height: 100%;
                max-height: 500px;
              `}
            >
              <div
                class='w-full h-full rounded-xl overflow-hidden'
                style='background: #FAFAFA;'
              >
                <img
                  src={image}
                  alt={`Cake ${index + 1}`}
                  class='w-full h-full object-cover'
                  style='object-fit: cover;'
                />
              </div>
            </div>
          ))
        }
      </div>

      <!-- Card Carousel Dots -->
      <!-- <div
        class='absolute bottom-8 left-0 right-0 z-20 flex justify-center gap-3'
      >
        {
          cakeImages.map((_, index) => (
            <button
              class={`card-dot w-2.5 h-2.5 rounded-full transition-all duration-300 ${index === 0 ? 'bg-gray-900 w-8' : 'bg-gray-400'}`}
              data-card-to={index}
              aria-label={`View cake ${index + 1}`}
            />
          ))
        }
      </div> -->
    </div>
  </div>
</section>

<!-- Scrolling Banner Section -->
<div
  class='border-y border-gray-200 py-4 overflow-hidden'
  style='background-color: #EBD7C8;'
>
  <div class='scroll-container'>
    <div class='scroll-content'>
      <!-- Repeat content for seamless scrolling -->
      <div class='flex items-center gap-8'>
        <!-- Cake Icon + Text -->
        <div class='flex items-center gap-3 whitespace-nowrap'>
          <svg
