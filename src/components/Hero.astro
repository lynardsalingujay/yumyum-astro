</div>

<style>
  .scroll-container {
    display: flex;
    overflow: hidden;
  }

  .scroll-content {
    display: flex;
    gap: 2rem;
    animation: scroll 30s linear infinite;
    will-change: transform;
  }

  @keyframes scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  /* Pause on hover */
  .scroll-container:hover .scroll-content {
    animation-play-state: paused;
  }

  /* Cascading card animation styles */
  .cake-card {
    position: absolute;
    left: 50%;
    top: 50%;
    transform-origin: center center;
  }

  .cake-card.active {
    transform: translate(-50%, -50%) rotate(0deg) scale(1);
    z-index: 3;
    opacity: 1;
  }

  .cake-card:not(.active):nth-child(1),
  .cake-card:not(.active):nth-child(2),
  .cake-card:not(.active):nth-child(3) {
    opacity: 0.7;
  }

  /* Add subtle bounce animation on load */
  @keyframes cardFloat {
    0%,
    100% {
      transform: translate(-50%, -50%) rotate(0deg) translateY(0);
    }
    50% {
      transform: translate(-50%, -50%) rotate(0deg) translateY(-10px);
    }
  }

  .cake-card.active {
    animation: cardFloat 4s ease-in-out infinite;
  }
</style>

<script>
  // Cascading card carousel with rotation effect
  let currentCard = 0
  const cards = document.querySelectorAll('.cake-card')
  const cardDots = document.querySelectorAll('.card-dot')
  const totalCards = cards.length
  let autoRotateInterval: number

  // Position cards in stacked/cascading layout
  function updateCardPositions(activeIndex: number) {
    cards.forEach((card, index) => {
      const htmlCard = card as HTMLElement

      // Remove active class from all
      card.classList.remove('active')

      if (index === activeIndex) {
        // Active card - front and center
        card.classList.add('active')
        htmlCard.style.transform = 'translate(-50%, -50%) rotate(0deg) scale(1)'
        htmlCard.style.zIndex = '3'
        htmlCard.style.opacity = '1'
      } else if (index === (activeIndex + 1) % totalCards) {
        // Next card - slightly behind and rotated
        htmlCard.style.transform =
          'translate(-45%, -48%) rotate(8deg) scale(0.92)'
        htmlCard.style.zIndex = '2'
        htmlCard.style.opacity = '0.6'
      } else if (index === (activeIndex + 2) % totalCards) {
        // Third card - further back
        htmlCard.style.transform =
          'translate(-40%, -46%) rotate(15deg) scale(0.84)'
        htmlCard.style.zIndex = '1'
        htmlCard.style.opacity = '0.3'
      } else {
        // Hidden cards
        htmlCard.style.transform =
          'translate(-50%, -50%) rotate(0deg) scale(0.8)'
        htmlCard.style.zIndex = '0'
        htmlCard.style.opacity = '0'
      }
    })

    // Update dots
    cardDots.forEach((dot, index) => {
      if (index === activeIndex) {
        dot.classList.remove('bg-gray-400')
        dot.classList.add('bg-gray-900', 'w-8')
      } else {
        dot.classList.remove('bg-gray-900', 'w-8')
        dot.classList.add('bg-gray-400')
      }
    })

    currentCard = activeIndex
  }

  function nextCard() {
    currentCard = (currentCard + 1) % totalCards
    updateCardPositions(currentCard)
  }

  function startAutoRotate() {
    autoRotateInterval = window.setInterval(nextCard, 3000) // 3 seconds
  }

  function stopAutoRotate() {
    if (autoRotateInterval) {
      clearInterval(autoRotateInterval)
    }
  }

  // Dot click handlers
  cardDots.forEach((dot, index) => {
    dot.addEventListener('click', () => {
      stopAutoRotate()
      updateCardPositions(index)
      startAutoRotate()
    })
  })

  // Initialize positions
  updateCardPositions(0)

  // Start auto-rotation when page loads
  startAutoRotate()

  // Pause on hover
  const carousel = document.getElementById('card-carousel')
  carousel?.addEventListener('mouseenter', stopAutoRotate)
  carousel?.addEventListener('mouseleave', startAutoRotate)
</script>
