---
// Footer component with contact info and links
---

<footer class="bg-primary-700 text-white py-10 sm:py-12">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 sm:gap-10">
      <div class="text-center sm:text-left">
        <h3 class="text-xl sm:text-2xl font-bold mb-3 sm:mb-4">YumYum</h3>
        <p class="text-red-50 text-sm sm:text-base">
          Bringing delicious flavors and memorable experiences to your table.
        </p>
      </div>
      <div class="text-center sm:text-left">
        <h4 class="text-lg sm:text-xl font-semibold mb-3 sm:mb-4">Quick Links</h4>
        <ul class="space-y-2">
          <li>
            <a
              href="/"
              class="text-red-50 hover:text-accent-300 transition-colors text-sm sm:text-base"
              >Home</a
            >
          </li>
          <li>
            <a
              href="/menu"
              class="text-red-50 hover:text-accent-300 transition-colors text-sm sm:text-base"
              >Menu</a
            >
          </li>
          <li>
            <a
              href="/about"
              class="text-red-50 hover:text-accent-300 transition-colors text-sm sm:text-base"
              >About</a
            >
          </li>
          <li>
            <a
              href="/contact"
              class="text-red-50 hover:text-accent-300 transition-colors text-sm sm:text-base"
              >Contact</a
            >
          </li>
        </ul>
      </div>
      <div class="text-center sm:text-left sm:col-span-2 lg:col-span-1">
        <h4 class="text-lg sm:text-xl font-semibold mb-3 sm:mb-4">Contact Us</h4>
        <p class="text-slate-200 mb-2 text-sm sm:text-base">Email: info@restaurant.com</p>
        <p class="text-slate-200 mb-2 text-sm sm:text-base">Phone: (555) 123-4567</p>
        <p class="text-slate-200 text-sm sm:text-base">123 Main Street, City, ST 12345</p>
      </div>
    </div>
    <div class="mt-8 pt-6 sm:pt-8 border-t border-primary-700 text-center">
      <p class="text-slate-200 text-xs sm:text-sm">
        &copy; 2026 Restaurant Name. All rights reserved.
      </p>
    </div>
  </div>
</footer>
